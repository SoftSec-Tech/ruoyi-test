<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysKnowledgeSnippetMapper">

    <resultMap type="SysKnowledgeSnippet" id="SysKnowledgeSnippetResult">
        <result property="snippetId"    column="snippet_id"    />
        <result property="categoryId"   column="category_id"   />
        <result property="snippetTitle" column="snippet_title" />
        <result property="snippetBody"  column="snippet_body"  />
        <result property="visibility"   column="visibility"    />
        <result property="viewCount"    column="view_count"    />
        <result property="status"       column="status"        />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"      column="remark"        />
    </resultMap>

    <sql id="selectSnippetVo">
        select snippet_id, category_id, snippet_title,
               cast(snippet_body as char) as snippet_body,
               visibility, view_count, status, create_by, create_time, update_by, update_time, remark
        from sys_knowledge_snippet
    </sql>

    <select id="selectSnippetById" parameterType="Long" resultMap="SysKnowledgeSnippetResult">
        <include refid="selectSnippetVo"/>
        where snippet_id = #{snippetId}
    </select>

    <select id="selectSnippetList" parameterType="SysKnowledgeSnippet" resultMap="SysKnowledgeSnippetResult">
        <include refid="selectSnippetVo"/>
        <where>
            <if test="snippetTitle != null and snippetTitle != ''">
                AND snippet_title like concat('%', #{snippetTitle}, '%')
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="visibility != null and visibility != ''">
                AND visibility = #{visibility}
            </if>
            <if test="createBy != null and createBy != ''">
                AND create_by like concat('%', #{createBy}, '%')
            </if>
        </where>
        <choose>
            <when test="sortColumn != null and sortColumn != ''">
                order by ${sortColumn} desc
            </when>
            <otherwise>
                order by snippet_id desc
            </otherwise>
        </choose>
    </select>

    <insert id="insertSnippet" parameterType="SysKnowledgeSnippet">
        insert into sys_knowledge_snippet (
            <if test="categoryId != null">category_id,</if>
            <if test="snippetTitle != null and snippetTitle != ''">snippet_title,</if>
            <if test="snippetBody != null and snippetBody != ''">snippet_body,</if>
            <if test="visibility != null and visibility != ''">visibility,</if>
            <if test="viewCount != null">view_count,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null and remark != ''">remark,</if>
            <if test="createBy != null and createBy != ''">create_by,</if>
            create_time
        ) values (
            <if test="categoryId != null">#{categoryId},</if>
            <if test="snippetTitle != null and snippetTitle != ''">#{snippetTitle},</if>
            <if test="snippetBody != null and snippetBody != ''">#{snippetBody},</if>
            <if test="visibility != null and visibility != ''">#{visibility},</if>
            <if test="viewCount != null">#{viewCount},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null and remark != ''">#{remark},</if>
            <if test="createBy != null and createBy != ''">#{createBy},</if>
            sysdate()
        )
    </insert>

    <update id="updateSnippet" parameterType="SysKnowledgeSnippet">
        update sys_knowledge_snippet
        <set>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="snippetTitle != null and snippetTitle != ''">snippet_title = #{snippetTitle},</if>
            <if test="snippetBody != null">snippet_body = #{snippetBody},</if>
            <if test="visibility != null and visibility != ''">visibility = #{visibility},</if>
            <if test="viewCount != null">view_count = #{viewCount},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
            update_time = sysdate()
        </set>
        where snippet_id = #{snippetId}
    </update>

    <delete id="deleteSnippetByIds">
        delete from sys_knowledge_snippet where snippet_id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <update id="incrementViewCount" parameterType="Long">
        update sys_knowledge_snippet set view_count = ifnull(view_count,0) + 1, update_time = sysdate()
        where snippet_id = #{snippetId}
    </update>

    <update id="updateStatusBatch">
        update sys_knowledge_snippet set status = #{status}, update_time = sysdate()
        where snippet_id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <select id="selectHotSnippets" resultMap="SysKnowledgeSnippetResult">
        <include refid="selectSnippetVo"/>
        where status = '1'
        order by view_count desc, snippet_id desc
        limit #{limit}
    </select>
</mapper>
